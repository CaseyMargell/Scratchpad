<Window x:Class="Scratchpad.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Scratchpad — Help"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="Segoe UI"
        Width="520"
        SizeToContent="Height"
        MaxHeight="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="18">
      <TextBlock Text="Scratchpad — Help" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,10" />

      <TextBlock Text="KEYBOARD SHORTCUTS" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,8,0,6" />
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
          <RowDefinition /><RowDefinition /><RowDefinition /><RowDefinition />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Enter" FontFamily="Cascadia Code, Consolas" Margin="0,2,12,2" />
        <TextBlock Grid.Row="0" Grid.Column="1" Text="Edit cell / submit" Margin="0,2" />
        <TextBlock Grid.Row="1" Grid.Column="0" Text="F2" FontFamily="Cascadia Code, Consolas" Margin="0,2,12,2" />
        <TextBlock Grid.Row="1" Grid.Column="1" Text="Edit cell" Margin="0,2" />
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Tab" FontFamily="Cascadia Code, Consolas" Margin="0,2,12,2" />
        <TextBlock Grid.Row="2" Grid.Column="1" Text="Next cell" Margin="0,2" />
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Esc" FontFamily="Cascadia Code, Consolas" Margin="0,2,12,2" />
        <TextBlock Grid.Row="3" Grid.Column="1" Text="Cancel edit" Margin="0,2" />
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Ctrl+Z / Ctrl+Y" FontFamily="Cascadia Code, Consolas" Margin="0,2,12,2" />
        <TextBlock Grid.Row="4" Grid.Column="1" Text="Undo / Redo" Margin="0,2" />
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Ctrl+C / X / V" FontFamily="Cascadia Code, Consolas" Margin="0,2,12,2" />
        <TextBlock Grid.Row="5" Grid.Column="1" Text="Copy / Cut / Paste (Excel-compatible)" Margin="0,2" />
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Ctrl+A" FontFamily="Cascadia Code, Consolas" Margin="0,2,12,2" />
        <TextBlock Grid.Row="6" Grid.Column="1" Text="Select all" Margin="0,2" />
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Shift + arrow / click" FontFamily="Cascadia Code, Consolas" Margin="0,2,12,2" />
        <TextBlock Grid.Row="7" Grid.Column="1" Text="Extend selection into range" Margin="0,2" />
      </Grid>

      <TextBlock Text="SUPPORTED FORMULAS" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,16,0,6" />
      <WrapPanel>
        <TextBlock Text="SUM(A1:A5)" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="AVERAGE(A1:A5)" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="MIN / MAX / COUNT" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="COUNTIF(A1:A5, &gt;10)" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="SUMIF(A1:A5, &gt;10)" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="IF(A1>5, &quot;yes&quot;, &quot;no&quot;)" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="ROUND(A1, 2)" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="ABS / SQRT" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="POWER(A1, 2)" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="MOD(A1, 3)" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="CONCATENATE(A1, B1)" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="UPPER / LOWER / TRIM" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="LEN / LEFT / RIGHT" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
        <TextBlock Text="TODAY() / NOW()" Margin="0,2,16,2" FontFamily="Cascadia Code, Consolas" Foreground="{DynamicResource TextSubtleBrush}" />
      </WrapPanel>

      <TextBlock Text="ABOUT" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextMutedBrush}" Margin="0,16,0,6" />
      <StackPanel Orientation="Horizontal">
        <Button Content="GitHub repo" Click="GithubBtn_Click" Padding="10,4" Margin="0,0,8,0"
                Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource AccentBrush}" BorderBrush="{DynamicResource BorderInputBrush}" />
        <Button Content="Casey on LinkedIn" Click="LinkedInBtn_Click" Padding="10,4"
                Background="{DynamicResource BgInputBrush}" Foreground="{DynamicResource AccentBrush}" BorderBrush="{DynamicResource BorderInputBrush}" />
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</Window>
