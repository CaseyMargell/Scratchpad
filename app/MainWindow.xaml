<Window x:Class="Scratchpad.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:Scratchpad"
        Title="Scratchpad"
        MinWidth="320" MinHeight="220"
        Background="{DynamicResource BgBrush}"
        Foreground="{DynamicResource TextBrush}"
        FontFamily="Segoe UI"
        WindowStartupLocation="Manual">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Toolbar -->
    <Border Grid.Row="0" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush1}" BorderThickness="0,0,0,1" Padding="10,6">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBox Grid.Column="0" x:Name="CellRefBox" Width="42" Height="24" IsReadOnly="True"
                 HorizontalContentAlignment="Center" Style="{DynamicResource ThemedTextBox}" Margin="0,0,6,0" />
        <TextBox Grid.Column="1" x:Name="FormulaBar" Height="24" Style="{DynamicResource ThemedTextBox}" />
        <StackPanel Grid.Column="2" Orientation="Horizontal" Margin="6,0,0,0">
          <Button x:Name="SaveBtn" Style="{DynamicResource IconButton}" Margin="2,0" ToolTip="Save as .xlsx" Click="SaveBtn_Click">
            <Path Data="M3,2 L10.6,2 14,5.4 14,14 2,14 2,2 Z M5,2 L5,6 11,6 11,2.4 10.6,2 Z M5,8 L11,8 11,14 5,14 Z" Fill="{DynamicResource TextMutedBrush}" Stretch="Uniform" Width="14" Height="14" />
          </Button>
          <Button x:Name="OpenBtn" Style="{DynamicResource IconButton}" Margin="2,0" ToolTip="Open .xlsx" Click="OpenBtn_Click">
            <Path Data="M1,3 L6,3 7.5,4.5 15,4.5 15,14 1,14 Z" Fill="{DynamicResource TextMutedBrush}" Stretch="Uniform" Width="14" Height="14" />
          </Button>
          <Button x:Name="ClearBtn" Style="{DynamicResource IconButton}" Margin="2,0" ToolTip="Clear all cells" Click="ClearBtn_Click">
            <Path Data="M4,4 L4,14 12,14 12,4 Z M6,1 L10,1 10,3 14,3 14,4 2,4 2,3 6,3 Z" Fill="{DynamicResource TextMutedBrush}" Stretch="Uniform" Width="14" Height="14" />
          </Button>
          <Button x:Name="SettingsBtn" Style="{DynamicResource IconButton}" Margin="2,0" ToolTip="Settings" Click="SettingsBtn_Click">
            <Path Data="M8,5.5 A2.5,2.5 0 1,0 8,10.5 A2.5,2.5 0 1,0 8,5.5 M7,1 L9,1 L9.3,2.5 L10.6,3.1 L12,2.5 L13.5,4 L12.9,5.4 L13.5,6.7 L15,7 L15,9 L13.5,9.3 L12.9,10.6 L13.5,12 L12,13.5 L10.6,12.9 L9.3,13.5 L9,15 L7,15 L6.7,13.5 L5.4,12.9 L4,13.5 L2.5,12 L3.1,10.6 L2.5,9.3 L1,9 L1,7 L2.5,6.7 L3.1,5.4 L2.5,4 L4,2.5 L5.4,3.1 L6.7,2.5 Z" Fill="{DynamicResource TextMutedBrush}" Stretch="Uniform" Width="14" Height="14" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- Grid -->
    <local:SpreadsheetGrid Grid.Row="1" x:Name="Grid1" />

    <!-- Status bar -->
    <Border Grid.Row="2" Background="{DynamicResource BgSurfaceBrush}" BorderBrush="{DynamicResource BorderBrush1}" BorderThickness="0,1,0,0" Padding="10,3">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <TextBlock Grid.Column="0" x:Name="StatusText" Text="Ready" Foreground="{DynamicResource TextMutedBrush}" FontSize="11" />
        <TextBlock Grid.Column="1" x:Name="StatsText" Foreground="{DynamicResource TextSubtleBrush}" FontSize="11" />
      </Grid>
    </Border>

    <!-- Floating help button -->
    <Button x:Name="HelpBtn" Grid.Row="1" HorizontalAlignment="Right" VerticalAlignment="Bottom"
            Margin="0,0,14,14" Width="32" Height="32" Cursor="Hand"
            ToolTip="Help &amp; info" Click="HelpBtn_Click">
      <Button.Template>
        <ControlTemplate TargetType="Button">
          <Border Background="{DynamicResource BgInputBrush}" BorderBrush="{DynamicResource BorderInputBrush}"
                  BorderThickness="1" CornerRadius="16">
            <TextBlock Text="?" Foreground="{DynamicResource TextMutedBrush}" FontSize="16" FontWeight="SemiBold"
                       HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Border>
        </ControlTemplate>
      </Button.Template>
    </Button>
  </Grid>
</Window>
